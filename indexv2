<script>
/* ===================================================================
   STORAGE HELPERS
=================================================================== */
async function getData(key, fallback){
  try{
    const r = await window.storage.get(key, false);
    if(!r || r.value === undefined || r.value === null) return fallback;
    return JSON.parse(r.value);
  }catch(e){ return fallback; }
}
async function setData(key, value){
  try{ await window.storage.set(key, JSON.stringify(value), false); }
  catch(e){ console.error('storage set failed', key, e); }
}
function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(showToast._t);
  showToast._t = setTimeout(()=>t.classList.remove('show'), 2200);
}

/* ===================================================================
   DATE / WEEK HELPERS
=================================================================== */
const DAY_NAMES = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
const DAY_FULL = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];

function getMonday(d){
  const date = new Date(d);
  const day = date.getDay(); // 0 Sun .. 6 Sat
  const diff = (day === 0 ? -6 : 1 - day);
  date.setDate(date.getDate() + diff);
  date.setHours(0,0,0,0);
  return date;
}
function isoDate(d){
  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
}
function fmtShort(d){ return d.toLocaleDateString('en-US',{month:'short', day:'numeric'}); }
function addDays(d, n){ const nd = new Date(d); nd.setDate(nd.getDate()+n); return nd; }

const TODAY = new Date();
const REAL_MONDAY = getMonday(TODAY); // the actual current week — used for Monday-modal + "Today" jump
let MONDAY = getMonday(TODAY);        // the week currently being viewed — navigable
let WEEK_KEY = isoDate(MONDAY);
let LAST_MONDAY = addDays(MONDAY, -7);
let LAST_WEEK_KEY = isoDate(LAST_MONDAY);
let WEEK_DATES = DAY_NAMES.map((_,i)=> addDays(MONDAY, i));

function updateWeekBadge(){
  const isCurrent = isoDate(MONDAY) === isoDate(REAL_MONDAY);
  document.getElementById('weekBadge').innerHTML =
    `Week of <b>${fmtShort(MONDAY)} – ${fmtShort(addDays(MONDAY,6))}</b>${isCurrent ? '' : ' <span style="opacity:.65;font-size:11px;">(viewing)</span>'}`;
  document.getElementById('todayWeekBtn').style.display = isCurrent ? 'none' : 'inline-flex';
}
async function loadWeekData(){
  STATE.weekdata = await getData('weekdata:'+WEEK_KEY, {intention:'', nonNegotiables:[], mondaySet:false});
  STATE.lastWeekTasks = await getData('tasks:'+LAST_WEEK_KEY, []);
  STATE.tasks = await getData('tasks:'+WEEK_KEY, []);
  STATE.scheduleModes = await getData('scheduleModes:'+WEEK_KEY, defaultModes());
  STATE.gymDays = await getData('gymDays:'+WEEK_KEY, defaultGymDays());
  STATE.blockOverrides = await getData('blockOverrides:'+WEEK_KEY, {});
  STATE.review = await getData('fridayreview:'+WEEK_KEY, null);
}
async function gotoWeek(newMonday){
  MONDAY = getMonday(newMonday);
  WEEK_KEY = isoDate(MONDAY);
  LAST_MONDAY = addDays(MONDAY, -7);
  LAST_WEEK_KEY = isoDate(LAST_MONDAY);
  WEEK_DATES = DAY_NAMES.map((_,i)=> addDays(MONDAY, i));
  await loadWeekData();
  updateWeekBadge();
  renderDashboard(); renderRotation(); renderSchedule(); renderTasksTab(); renderGoalsTab(); renderReviewTab();
}
document.getElementById('prevWeekBtn').addEventListener('click', ()=> gotoWeek(addDays(MONDAY, -7)));
document.getElementById('nextWeekBtn').addEventListener('click', ()=> gotoWeek(addDays(MONDAY, 7)));
document.getElementById('todayWeekBtn').addEventListener('click', ()=> gotoWeek(REAL_MONDAY));

/* ===================================================================
   CATEGORIES
=================================================================== */
const CATS = {
  faith:     {label:'Faith',        color:'var(--burgundy)', text:'#FDF6EC'},
  gym:       {label:'Gym',          color:'var(--gold)',     text:'#1C1210'},
  work:      {label:'Databricks',   color:'var(--noir)',     text:'#FDF6EC', border:'1px solid rgba(253,246,236,0.25)'},
  content:   {label:'Content',      color:'var(--magenta)',  text:'#FDF6EC'},
  orgsocial: {label:'Org Social',   color:'var(--peach)',    text:'#1C1210'},
  personal:  {label:'Personal',     color:'var(--cream)',    text:'#1C1210'},
  reset:     {label:'Reset',        color:'var(--red)',      text:'#FDF6EC'},
};

/* ===================================================================
   SCHEDULE BLOCK DEFINITIONS
=================================================================== */
function heavyBlocks(gymOn){
  const blocks = [
    {id:'devotion', s:'7:45', e:'8:45', label:'Devotion + Breakfast', cat:'faith'},
    {id:'buffer', s:'8:45', e:'9:45', label:'Get ready / low-key admin', cat:'personal'},
    {id:'work', s:'9:45', e:'17:00', label:'Databricks (logged on, heads down)', cat:'work'},
    {id:'dinner', s:'17:00', e:'18:00', label:'Dinner', cat:'personal'},
    {id:'content', s:'18:00', e:'20:00', label:'Content Creation', cat:'content'},
  ];
  if(gymOn){
    blocks.push({id:'evening', s:'20:00', e:'20:30', label:'Wind down / buffer', cat:'personal', rotatable:true});
    blocks.push({id:'gym', s:'20:30', e:'21:30', label:'Gym (late night)', cat:'gym'});
  } else {
    blocks.push({id:'evening', s:'20:00', e:'21:30', label:'Wind down / buffer', cat:'personal', rotatable:true});
  }
  return blocks;
}
function lightBlocks(gymOn){
  const blocks = [
    {id:'devotion', s:'7:45', e:'8:45', label:'Devotion + Breakfast', cat:'faith'},
    {id:'buffer', s:'8:45', e:'9:45', label:'Get ready / low-key admin', cat:'personal'},
    {id:'content1', s:'9:45', e:'11:30', label:'Content Shoot/Edit + Databricks (background)', cat:'content'},
    {id:'orgsocial1', s:'11:30', e:'13:30', label:'Org Social Media + Databricks (background)', cat:'orgsocial'},
    {id:'work', s:'13:30', e:'17:00', label:'Databricks (light) + coffee shop', cat:'work'},
    {id:'dinner', s:'17:00', e:'18:00', label:'Dinner', cat:'personal'},
  ];
  if(gymOn){
    blocks.push({id:'evening', s:'18:00', e:'20:00', label:'Flex block', cat:'personal', rotatable:true});
    blocks.push({id:'gym', s:'20:30', e:'21:30', label:'Gym (late night)', cat:'gym'});
  } else {
    blocks.push({id:'evening', s:'18:00', e:'21:30', label:'Flex block', cat:'personal', rotatable:true});
  }
  return blocks;
}
function applyRotation(blocks, dayName, rotation){
  if(dayName==='Wed'){
    const label = rotation.wed==='bible' ? 'Bible Study' : 'Free evening';
    blocks = blocks.map(b=> b.rotatable ? {...b, label, cat: rotation.wed==='bible'?'faith':'personal'} : b);
  }
  if(dayName==='Thu'){
    const label = rotation.thu==='therapy' ? 'Therapy' : 'Rest';
    blocks = blocks.map(b=> b.rotatable ? {...b, label, cat: rotation.thu==='therapy'?'faith':'personal'} : b);
  }
  return blocks;
}
function weekendBlocks(dayName, mode, gymOn){
  if(dayName==='Sun'){
    const blocks = [
      {id:'church', s:'10:30', e:'12:00', label:'Church', cat:'faith'},
      {id:'mealprep', s:'12:00', e:'13:00', label:'Meal prep + batch org social posts', cat:'orgsocial'},
      {id:'planshoot', s:'13:00', e:'14:00', label:'Plan content shoot day', cat:'content'},
    ];
    if(gymOn) blocks.push({id:'gym', s:'20:30', e:'21:30', label:'Gym (late night)', cat:'gym'});
    return blocks;
  }
  // Saturday
  let blocks;
  if(mode==='travel'){
    blocks = [
      {id:'walk', s:'6:30', e:'7:30', label:'Long walk', cat:'personal'},
      {id:'devotion', s:'7:30', e:'8:00', label:'Devotion', cat:'faith'},
      {id:'travel', s:'9:00', e:'20:00', label:'Travel + content capture', cat:'content'},
    ];
  } else {
    blocks = [
      {id:'walk', s:'6:30', e:'7:30', label:'Long walk', cat:'personal'},
      {id:'devotion', s:'7:30', e:'8:30', label:'Devotion + Breakfast', cat:'faith'},
      {id:'deepedit', s:'11:00', e:'13:30', label:'Deep edit block', cat:'content'},
      {id:'rest', s:'14:00', e:'20:00', label:'Actual rest', cat:'personal'},
    ];
  }
  if(gymOn) blocks.push({id:'gym', s:'20:30', e:'21:30', label:'Gym (late night)', cat:'gym'});
  return blocks;
}
function applyOverrides(blocks, dayName){
  const dayOverrides = (STATE.blockOverrides && STATE.blockOverrides[dayName]) || {};
  return blocks.map(b=>{
    const o = dayOverrides[b.id];
    return o ? {...b, s:o.s, e:o.e, label:o.label, overridden:true} : b;
  });
}
function getBlocksFor(dayName, mode, rotation, gymOn){
  let blocks;
  if(dayName==='Sat' || dayName==='Sun'){
    blocks = weekendBlocks(dayName, mode, gymOn);
  } else {
    blocks = mode==='heavy' ? heavyBlocks(gymOn) : lightBlocks(gymOn);
    blocks = applyRotation(blocks, dayName, rotation);
  }
  return applyOverrides(blocks, dayName);
}

/* ===================================================================
   TAB NAVIGATION
=================================================================== */
document.getElementById('tabNav').addEventListener('click', e=>{
  const btn = e.target.closest('button[data-tab]');
  if(!btn) return;
  document.querySelectorAll('nav.tabs button').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('section.tab').forEach(s=>s.classList.remove('active'));
  document.getElementById('tab-'+btn.dataset.tab).classList.add('active');
});

/* ===================================================================
   APP STATE
=================================================================== */
let STATE = {
  weekdata: null,        // {intention, nonNegotiables:[{text,done}], mondaySet}
  lastWeekTasks: [],
  tasks: [],              // this week's tasks
  rotation: {wed:'bible', thu:'therapy'},
  goals: [],
  scheduleModes: {},
  gymDays: {},
  blockOverrides: {},
  programStart: null,
  vision: '',
  review: null,
  budget: null,
};

/* ===================================================================
   INIT
=================================================================== */
async function init(){
  await loadWeekData();
  STATE.rotation = await getData('rotation', {wed:'bible', thu:'therapy'});
  STATE.goals = await getData('goals12week', []);
  STATE.programStart = await getData('twelveWeekProgramStart', WEEK_KEY);
  STATE.vision = await getData('twelveWeekVision', '');
  STATE.budget = await getData('budget', {categories:[
      {name:'Rent', budget:0},{name:'Utilities', budget:0},{name:'Car Payment', budget:0},
      {name:'Groceries', budget:0},{name:'Fun Money', budget:0},{name:'Random Spending', budget:0},{name:'Everything Else', budget:0}
    ], entries:[], weeklyPay:0});

  updateWeekBadge();
  renderDashboard();
  renderRotation();
  renderSchedule();
  renderTasksTab();
  renderGoalsTab();
  renderVision();
  renderReviewTab();
  renderBudgetTab();
  maybeShowMondayModal();
}
function defaultModes(){
  const m = {};
  DAY_NAMES.forEach(d=>{
    if(d==='Sat') m[d]='home'; else if(d!=='Sun') m[d]='heavy';
  });
  return m;
}
function defaultGymDays(){
  // starting suggestion for 3-4x/week — toggle any day on/off
  return {Mon:false, Tue:true, Wed:true, Thu:false, Fri:true, Sat:true, Sun:false};
}

/* ===================================================================
   DASHBOARD
=================================================================== */
function completion(tasks){
  if(!tasks.length) return {done:0,total:0,pct:0};
  const done = tasks.filter(t=>t.done).length;
  return {done, total:tasks.length, pct: Math.round(done/tasks.length*100)};
}
function renderDashboard(){
  const thisC = completion(STATE.tasks);
  const lastC = completion(STATE.lastWeekTasks);
  document.getElementById('progThis').style.width = thisC.pct+'%';
  document.getElementById('progThisPct').textContent = thisC.pct+'%';
  document.getElementById('progLast').style.width = lastC.pct+'%';
  document.getElementById('progLastPct').textContent = lastC.pct+'%';
  const note = document.getElementById('progNote');
  if(!thisC.total && !lastC.total){ note.textContent = 'Add tasks in the Tasks tab to start tracking.'; }
  else {
    const diff = thisC.pct - lastC.pct;
    note.textContent = diff===0 ? 'Even with last week so far.' : (diff>0 ? `Up ${diff}% from last week.` : `Down ${Math.abs(diff)}% from last week — still time to close it.`);
  }

  // non-negotiables
  const nnList = document.getElementById('nnList');
  nnList.innerHTML = '';
  const nns = STATE.weekdata.nonNegotiables || [];
  if(!nns.length){
    nnList.innerHTML = '<p class="empty">No non-negotiables set yet — set your Monday intention to add three.</p>';
  } else {
    nns.forEach((nn, i)=>{
      const row = document.createElement('div');
      row.className = 'nn-item';
      row.innerHTML = `<input type="checkbox" ${nn.done?'checked':''}> <span class="${nn.done?'done':''}">${escapeHtml(nn.text)}</span>`;
      row.querySelector('input').addEventListener('change', async e=>{
        STATE.weekdata.nonNegotiables[i].done = e.target.checked;
        await setData('weekdata:'+WEEK_KEY, STATE.weekdata);
        renderDashboard();
      });
      nnList.appendChild(row);
    });
  }

  // 12 week priorities preview
  const weekNum = getWeekNumber();
  document.getElementById('twYearSub').textContent = `Week ${weekNum} of 12`;
  const dashGoals = document.getElementById('dashGoals');
  dashGoals.innerHTML = '';
  if(!STATE.goals.length){
    dashGoals.innerHTML = '<p class="empty">No goals yet — add them in the 12 Week Year tab.</p>';
  } else {
    const sorted = [...STATE.goals].sort((a,b)=> priorityRank(a.priority)-priorityRank(b.priority));
    sorted.forEach(g=>{
      const row = document.createElement('div');
      row.className = 'goal-row';
      const score = goalWeekScore(g, weekNum);
      const scoreTxt = score.total ? `${score.pct}%` : 'no tactics yet';
      row.innerHTML = `<span>${escapeHtml(g.title)}</span><span class="pill pill-${g.priority}">${g.priority} · ${scoreTxt}</span>`;
      dashGoals.appendChild(row);
    });
  }
}
function priorityRank(p){ return p==='high'?0:p==='medium'?1:2; }
function getWeekNumber(){
  const start = STATE.programStart ? new Date(STATE.programStart) : MONDAY;
  const diffDays = Math.round((MONDAY - start) / 86400000);
  const wk = Math.floor(diffDays / 7) + 1;
  return Math.min(12, Math.max(1, wk));
}
function goalWeekScore(g, weekNum){
  const tactics = g.tactics || [];
  const wd = (g.weekData && g.weekData[weekNum]) || {};
  const total = tactics.length;
  const done = tactics.filter(t=>wd[t.id]).length;
  return {done, total, pct: total ? Math.round(done/total*100) : 0};
}
function escapeHtml(s){
  const d = document.createElement('div'); d.textContent = s||''; return d.innerHTML;
}

document.getElementById('openIntentionBtn').addEventListener('click', ()=> openMondayModal(true));

/* ===================================================================
   ROTATION TOGGLE
=================================================================== */
function renderRotation(){
  const wed = document.getElementById('toggleWed');
  const thu = document.getElementById('toggleThu');
  wed.classList.toggle('right', STATE.rotation.wed==='free');
  thu.classList.toggle('right', STATE.rotation.thu==='rest');
  wed.onclick = async ()=>{
    STATE.rotation.wed = STATE.rotation.wed==='bible' ? 'free' : 'bible';
    await setData('rotation', STATE.rotation);
    renderRotation(); renderSchedule(); renderTasksTab();
  };
  thu.onclick = async ()=>{
    STATE.rotation.thu = STATE.rotation.thu==='therapy' ? 'rest' : 'therapy';
    await setData('rotation', STATE.rotation);
    renderRotation(); renderSchedule(); renderTasksTab();
  };
}

/* ===================================================================
   SCHEDULE TAB
=================================================================== */
function renderModeControls(){
  const wrap = document.getElementById('modeControls');
  wrap.innerHTML = '';
  DAY_NAMES.forEach(d=>{
    if(d==='Sun') return;
    const chip = document.createElement('div');
    chip.className = 'mode-chip';
    const options = d==='Sat' ? ['home','travel'] : ['heavy','light'];
    const labels = d==='Sat' ? ['Home','Travel'] : ['Heavy','Light'];
    chip.innerHTML = `<div class="day-lbl">${d}</div>
      <div class="mini-toggle">
        <button data-val="${options[0]}" class="${STATE.scheduleModes[d]===options[0]?'on':''}">${labels[0]}</button>
        <button data-val="${options[1]}" class="${STATE.scheduleModes[d]===options[1]?'on':''}">${labels[1]}</button>
      </div>`;
    chip.querySelectorAll('button').forEach(b=>{
      b.addEventListener('click', async ()=>{
        STATE.scheduleModes[d] = b.dataset.val;
        await setData('scheduleModes:'+WEEK_KEY, STATE.scheduleModes);
        renderModeControls(); renderSchedule(); renderTasksTab();
      });
    });
    wrap.appendChild(chip);
  });
}
function renderGymControls(){
  const wrap = document.getElementById('gymControls');
  wrap.innerHTML = '';
  DAY_NAMES.forEach(d=>{
    const on = !!STATE.gymDays[d];
    const chip = document.createElement('div');
    chip.className = 'mode-chip';
    chip.innerHTML = `<div class="day-lbl">${d}</div>
      <div class="mini-toggle">
        <button data-val="off" class="${!on?'on':''}">Off</button>
        <button data-val="on" class="${on?'on':''}">Gym</button>
      </div>`;
    chip.querySelectorAll('button').forEach(b=>{
      b.addEventListener('click', async ()=>{
        STATE.gymDays[d] = b.dataset.val==='on';
        await setData('gymDays:'+WEEK_KEY, STATE.gymDays);
        renderGymControls(); renderSchedule(); renderTasksTab();
      });
    });
    wrap.appendChild(chip);
  });
}
function timeToRow(t){
  const [h,m] = t.split(':').map(Number);
  return (h-6)*2 + (m>=30?1:0) + 2; // +2: row1 = day headers
}
function renderSchedule(){
  renderModeControls();
  renderGymControls();
  const grid = document.getElementById('schedGrid');
  grid.innerHTML = '';
  grid.style.gridTemplateRows = `32px repeat(34, 20px)`;

  // corner
  const corner = document.createElement('div'); corner.style.gridColumn='1'; corner.style.gridRow='1';
  grid.appendChild(corner);

  // day headers
  DAY_NAMES.forEach((d,i)=>{
    const head = document.createElement('div');
    head.className = 'day-head';
    head.style.gridColumn = (i+2);
    head.style.gridRow = 1;
    head.innerHTML = `${DAY_FULL[i]}<b>${fmtShort(WEEK_DATES[i])}</b>`;
    grid.appendChild(head);
  });

  // time labels every hour
  for(let h=6; h<=23; h++){
    const lbl = document.createElement('div');
    lbl.className = 'time-lbl';
    lbl.style.gridRow = ((h-6)*2 + 2);
    lbl.style.gridColumn = 1;
    lbl.textContent = (h>12 ? h-12 : h) + (h>=12?'p':'a');
    grid.appendChild(lbl);
  }

  // blocks
  DAY_NAMES.forEach((d,i)=>{
    const mode = STATE.scheduleModes[d] || (d==='Sat'?'home':'heavy');
    const blocks = getBlocksFor(d, mode, STATE.rotation, STATE.gymDays[d]);
    blocks.forEach(b=>{
      const cat = CATS[b.cat];
      const div = document.createElement('div');
      div.className = 'block' + (b.overridden ? ' edited' : '');
      div.style.gridColumn = (i+2);
      div.style.gridRow = `${timeToRow(b.s)} / ${timeToRow(b.e)}`;
      div.style.background = cat.color;
      div.style.color = cat.text;
      if(cat.border) div.style.border = cat.border;
      div.innerHTML = `<span class="t">${b.s}–${b.e}</span>${escapeHtml(b.label)}`;
      div.addEventListener('click', ()=> openBlockEdit(d, b));
      grid.appendChild(div);
    });
  });

  // legend
  const legend = document.getElementById('legend');
  legend.innerHTML = Object.values(CATS).map(c=>`<span><i style="background:${c.color}"></i>${c.label}</span>`).join('');
}

