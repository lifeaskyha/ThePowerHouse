/* ===================================================================
   GOOGLE CALENDAR — real two-way sync
   To activate: create an OAuth Client ID in Google Cloud Console
   (Web application type, authorized origin = your site's URL) and
   paste it below. Until then, the .ics fallback always works.
=================================================================== */
const GOOGLE_CLIENT_ID = 'PASTE_YOUR_CLIENT_ID_HERE.apps.googleusercontent.com';
let gcalTokenClient = null;
let gcalAccessToken = null;

function gcalConfigured(){ return GOOGLE_CLIENT_ID && !GOOGLE_CLIENT_ID.includes('PASTE_YOUR'); }
function initGcal(){
  if(!gcalConfigured() || !window.google || !google.accounts) return false;
  if(gcalTokenClient) return true;
  gcalTokenClient = google.accounts.oauth2.initTokenClient({
    client_id: GOOGLE_CLIENT_ID,
    scope: 'https://www.googleapis.com/auth/calendar.events',
    callback: (resp)=>{
      if(resp.error){ showToast('Google sign-in failed — try again'); return; }
      gcalAccessToken = resp.access_token;
      document.getElementById('gcalStatus').textContent = 'Connected';
      document.getElementById('gcalConnectBtn').textContent = 'Reconnect';
      document.getElementById('gcalPushBtn').style.display = 'inline-flex';
      document.getElementById('gcalPullBtn').style.display = 'inline-flex';
      showToast('Google Calendar connected');
    }
  });
  return true;
}
document.getElementById('gcalConnectBtn').addEventListener('click', ()=>{
  if(!gcalConfigured()){
    showToast('Add your Google Client ID in the code first — see setup notes');
    return;
  }
  if(!initGcal()){
    showToast('Google sign-in is still loading — try again in a moment');
    return;
  }
  gcalTokenClient.requestAccessToken();
});

function pad(n){ return String(n).padStart(2,'0'); }
function toRfc3339(date, timeStr){
  const [h,m] = timeStr.split(':').map(Number);
  const d = new Date(date); d.setHours(h,m,0,0);
  const off = -d.getTimezoneOffset();
  const sign = off>=0 ? '+' : '-';
  const oh = pad(Math.floor(Math.abs(off)/60)), om = pad(Math.abs(off)%60);
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}:00${sign}${oh}:${om}`;
}

document.getElementById('gcalPushBtn').addEventListener('click', async ()=>{
  if(!gcalAccessToken){ showToast('Connect Google Calendar first'); return; }
  showToast('Pushing this week to Google Calendar…');
  let count = 0;
  for(let i=0; i<DAY_NAMES.length; i++){
    const d = DAY_NAMES[i];
    const mode = STATE.scheduleModes[d] || (d==='Sat'?'home':'heavy');
    const blocks = getBlocksFor(d, mode, STATE.rotation, STATE.gymDays[d]);
    for(const b of blocks){
      const event = {
        summary: b.label,
        start: {dateTime: toRfc3339(WEEK_DATES[i], b.s)},
        end: {dateTime: toRfc3339(WEEK_DATES[i], b.e)},
      };
      try{
        const res = await fetch('https://www.googleapis.com/calendar/v3/calendars/primary/events', {
          method:'POST',
          headers:{'Authorization':'Bearer '+gcalAccessToken, 'Content-Type':'application/json'},
          body: JSON.stringify(event)
        });
        if(res.ok) count++;
      }catch(e){ /* skip failed event, keep going */ }
    }
  }
  showToast(`Pushed ${count} blocks to Google Calendar`);
});

document.getElementById('gcalPullBtn').addEventListener('click', async ()=>{
  if(!gcalAccessToken){ showToast('Connect Google Calendar first'); return; }
  const timeMin = new Date(WEEK_DATES[0]); timeMin.setHours(0,0,0,0);
  const timeMax = new Date(WEEK_DATES[6]); timeMax.setHours(23,59,59,999);
  const url = `https://www.googleapis.com/calendar/v3/calendars/primary/events?timeMin=${encodeURIComponent(timeMin.toISOString())}&timeMax=${encodeURIComponent(timeMax.toISOString())}&singleEvents=true&orderBy=startTime`;
  try{
    const res = await fetch(url, {headers:{'Authorization':'Bearer '+gcalAccessToken}});
    if(!res.ok){ showToast('Could not load calendar events'); return; }
    const data = await res.json();
    renderGcalEvents(data.items || []);
    showToast(`Pulled ${(data.items||[]).length} events from Google Calendar`);
  }catch(e){ showToast('Could not load calendar events'); }
});
function renderGcalEvents(events){
  const card = document.getElementById('gcalEventsCard');
  const list = document.getElementById('gcalEventsList');
  if(!events.length){
    list.innerHTML = '<p class="empty">Nothing found on your Google Calendar this week.</p>';
  } else {
    list.innerHTML = events.map(ev=>{
      const dt = ev.start && ev.start.dateTime ? new Date(ev.start.dateTime) : null;
      const timeStr = dt
        ? dt.toLocaleString('en-US',{weekday:'short', hour:'numeric', minute:'2-digit'})
        : (ev.start && ev.start.date ? new Date(ev.start.date).toLocaleDateString('en-US',{weekday:'short', month:'short', day:'numeric'})+' · All day' : '');
      return `<div class="mini-block" style="padding:6px 0;"><i style="background:var(--peach)"></i>${escapeHtml(timeStr)} — ${escapeHtml(ev.summary||'(untitled)')}</div>`;
    }).join('');
  }
  card.style.display = 'block';
}

/* ---- .ics fallback (no sign-in required) ---- */
function icsDate(date, timeStr){
  const [h,m] = timeStr.split(':').map(Number);
  const d = new Date(date);
  d.setHours(h, m, 0, 0);
  return d.getFullYear()+pad(d.getMonth()+1)+pad(d.getDate())+'T'+pad(d.getHours())+pad(d.getMinutes())+'00';
}
document.getElementById('gcalIcsBtn').addEventListener('click', ()=>{
  let ics = 'BEGIN:VCALENDAR\r\nVERSION:2.0\r\nPRODID:-//Command Center//EN\r\n';
  DAY_NAMES.forEach((d,i)=>{
    const mode = STATE.scheduleModes[d] || (d==='Sat'?'home':'heavy');
    const blocks = getBlocksFor(d, mode, STATE.rotation, STATE.gymDays[d]);
    blocks.forEach(b=>{
      ics += 'BEGIN:VEVENT\r\n';
      ics += 'UID:'+Date.now()+Math.random().toString(16).slice(2)+'@commandcenter\r\n';
      ics += 'DTSTART:'+icsDate(WEEK_DATES[i], b.s)+'\r\n';
      ics += 'DTEND:'+icsDate(WEEK_DATES[i], b.e)+'\r\n';
      ics += 'SUMMARY:'+b.label+'\r\n';
      ics += 'END:VEVENT\r\n';
    });
  });
  ics += 'END:VCALENDAR';
  const blob = new Blob([ics], {type:'text/calendar'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'command-center-week.ics';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showToast('Calendar file downloaded — import it in Google Calendar');
});

init();
</script>
