<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Command Center</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600;1,700&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://accounts.google.com/gsi/client" async defer></script>
<style>
  :root{
    --cream:#FDF6EC;
    --peach:#F4B183;
    --gold:#F2C14E;
    --magenta:#D6336C;
    --red:#E63946;
    --burgundy:#6A0F23;
    --noir:#1C1210;
    --ink:#241A18;
    --line:rgba(28,18,16,0.1);
    --shadow: 0 10px 30px rgba(28,18,16,0.18);
    --radius: 16px;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:
      radial-gradient(ellipse at top left, rgba(214,51,108,0.18), transparent 55%),
      radial-gradient(ellipse at bottom right, rgba(106,15,35,0.35), transparent 55%),
      var(--noir);
    color:var(--cream);
    font-family:'Jost', sans-serif;
    min-height:100vh;
    padding-bottom:60px;
  }
  h1,h2,h3,.display{font-family:'Playfair Display', serif;}
  .wrap{max-width:1180px;margin:0 auto;padding:28px 20px 0;}

  /* ---------- HEADER ---------- */
  header.top{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-end;gap:14px;margin-bottom:22px;}
  .brand-eyebrow{font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--peach);margin:0 0 4px;}
  .brand-title{font-style:italic;font-weight:700;font-size:clamp(28px,4vw,42px);margin:0;color:var(--cream);}
  .week-badge{
    background:linear-gradient(135deg, var(--burgundy), var(--magenta));
    border-radius:999px;padding:10px 20px;font-size:13px;letter-spacing:.04em;
    box-shadow:var(--shadow); white-space:nowrap;
  }
  .week-badge b{font-family:'Playfair Display',serif;font-style:italic;}

  /* ---------- NAV ---------- */
  nav.tabs{
    display:flex;gap:6px;flex-wrap:wrap;
    background:rgba(253,246,236,0.05);
    border:1px solid rgba(253,246,236,0.1);
    padding:6px;border-radius:999px;margin-bottom:26px;
    backdrop-filter:blur(6px);
  }
  nav.tabs button{
    flex:1 1 auto;min-width:110px;
    border:none;background:transparent;color:var(--cream);opacity:.65;
    font-family:'Jost',sans-serif;font-size:13px;letter-spacing:.05em;text-transform:uppercase;
    padding:11px 14px;border-radius:999px;cursor:pointer;transition:.2s;
  }
  nav.tabs button:hover{opacity:1;}
  nav.tabs button.active{
    opacity:1;color:var(--noir);
    background:linear-gradient(120deg, var(--gold), var(--peach));
    font-weight:600; box-shadow:var(--shadow);
  }

  section.tab{display:none;animation:fade .35s ease;}
  section.tab.active{display:block;}
  @keyframes fade{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

  .card{
    background:linear-gradient(160deg, rgba(253,246,236,0.06), rgba(253,246,236,0.02));
    border:1px solid rgba(253,246,236,0.12);
    border-radius:var(--radius);
    padding:22px;
    margin-bottom:20px;
  }
  .card h2{margin:0 0 4px;font-size:20px;font-style:italic;}
  .card .sub{font-size:12px;color:var(--peach);text-transform:uppercase;letter-spacing:.12em;margin-bottom:16px;}
  .grid-2{display:grid;grid-template-columns:1.3fr 1fr;gap:20px;}
  .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  @media(max-width:860px){.grid-2,.grid-3{grid-template-columns:1fr;}}

  button.btn{
    font-family:'Jost',sans-serif;border:none;cursor:pointer;border-radius:10px;
    padding:11px 18px;font-size:13px;letter-spacing:.03em;font-weight:500;transition:.15s;
  }
  .btn-primary{background:linear-gradient(120deg,var(--magenta),var(--burgundy));color:var(--cream);}
  .btn-primary:hover{filter:brightness(1.1);}
  .btn-ghost{background:rgba(253,246,236,0.08);color:var(--cream);border:1px solid rgba(253,246,236,0.2);}
  .btn-ghost:hover{background:rgba(253,246,236,0.15);}
  .btn-gold{background:linear-gradient(120deg,var(--gold),var(--peach));color:var(--noir);font-weight:600;}
  .btn-sm{padding:7px 12px;font-size:12px;border-radius:8px;}
  .btn-danger{background:rgba(230,57,70,0.18);color:#ffb4ba;border:1px solid rgba(230,57,70,0.4);}

  input[type=text],input[type=number],input[type=date],select,textarea{
    width:100%;background:rgba(253,246,236,0.07);border:1px solid rgba(253,246,236,0.18);
    color:var(--cream);border-radius:9px;padding:9px 12px;font-family:'Jost',sans-serif;font-size:13.5px;
  }
  textarea{resize:vertical;min-height:64px;}
  label{font-size:11.5px;text-transform:uppercase;letter-spacing:.08em;color:var(--peach);display:block;margin-bottom:5px;}
  .field{margin-bottom:12px;}

  /* ---------- NON-NEGOTIABLES ---------- */
  .nn-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;background:rgba(253,246,236,0.05);margin-bottom:8px;}
  .nn-item input[type=checkbox]{width:19px;height:19px;accent-color:var(--gold);}
  .nn-item span.done{text-decoration:line-through;opacity:.5;}

  /* ---------- PROGRESS ---------- */
  .prog-row{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
  .prog-label{width:90px;font-size:12px;text-transform:uppercase;letter-spacing:.06em;color:var(--peach);}
  .prog-track{flex:1;height:14px;background:rgba(253,246,236,0.08);border-radius:999px;overflow:hidden;}
  .prog-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--gold),var(--magenta));}
  .prog-pct{width:42px;text-align:right;font-size:12px;color:var(--cream);}

  /* ---------- GOALS / PRIORITY ---------- */
  .goal-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--line);}
  .goal-row:last-child{border-bottom:none;}
  .pill{padding:3px 10px;border-radius:999px;font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;font-weight:600;}
  .pill-high{background:var(--red);color:#fff;}
  .pill-medium{background:var(--gold);color:var(--noir);}
  .pill-low{background:rgba(253,246,236,0.15);color:var(--cream);}

  /* ---------- TOGGLE SWITCH ---------- */
  .toggle-row{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--line);}
  .toggle-row:last-child{border-bottom:none;}
  .switch{position:relative;width:120px;height:34px;background:rgba(253,246,236,0.1);border-radius:999px;cursor:pointer;display:flex;align-items:center;padding:3px;}
  .switch .knob{position:absolute;top:3px;left:3px;width:58px;height:28px;border-radius:999px;background:linear-gradient(120deg,var(--magenta),var(--burgundy));transition:.25s;display:flex;align-items:center;justify-content:center;font-size:10.5px;text-transform:uppercase;letter-spacing:.04em;}
  .switch.right .knob{left:59px;background:linear-gradient(120deg,var(--gold),var(--peach));color:var(--noir);}
  .switch .lbl{position:absolute;font-size:10px;text-transform:uppercase;letter-spacing:.04em;color:rgba(253,246,236,0.55);}
  .switch .lbl.l{left:10px;} .switch .lbl.r{right:8px;}

  /* ---------- SCHEDULE GRID ---------- */
  .sched-controls{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;}
  .mode-chip{display:flex;flex-direction:column;align-items:center;gap:6px;background:rgba(253,246,236,0.05);border-radius:12px;padding:8px 10px;}
  .mode-chip .day-lbl{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--peach);}
  .mini-toggle{display:flex;border-radius:999px;overflow:hidden;border:1px solid rgba(253,246,236,0.2);}
  .mini-toggle button{border:none;background:transparent;color:var(--cream);font-size:11px;padding:5px 10px;cursor:pointer;opacity:.6;}
  .mini-toggle button.on{opacity:1;background:linear-gradient(120deg,var(--magenta),var(--burgundy));}
  .sched-scroll{overflow-x:auto;}
  .sched-grid{
    display:grid;
    grid-template-columns:56px repeat(7, minmax(118px,1fr));
    grid-auto-rows:20px;
    min-width:900px;
    position:relative;
  }
  .time-lbl{grid-column:1;font-size:10px;color:rgba(253,246,236,0.4);text-align:right;padding-right:8px;transform:translateY(-6px);}
  .day-head{position:sticky;top:0;background:var(--noir);padding:8px 4px;font-size:12px;text-align:center;border-bottom:2px solid rgba(253,246,236,0.15);z-index:2;}
  .day-head b{display:block;font-family:'Playfair Display',serif;font-style:italic;font-size:14px;}
  .grid-line{grid-column:2/9;border-top:1px solid rgba(253,246,236,0.06);}
  .block{
    margin:1px 3px;border-radius:8px;padding:6px 8px;font-size:11px;line-height:1.25;
    box-shadow:0 4px 10px rgba(0,0,0,0.25);overflow:hidden;position:relative;cursor:pointer;transition:.15s;
  }
  .block:hover{filter:brightness(1.12);outline:2px solid rgba(253,246,236,0.4);}
  .block.edited::after{content:'✎';position:absolute;top:4px;right:6px;font-size:10px;opacity:.8;}
  .block .t{display:block;font-size:9.5px;opacity:.85;margin-bottom:2px;text-transform:uppercase;letter-spacing:.03em;}
  .legend{display:flex;flex-wrap:wrap;gap:10px;margin-top:16px;}
  .legend span{display:flex;align-items:center;gap:6px;font-size:11.5px;color:rgba(253,246,236,0.75);}
  .legend i{width:11px;height:11px;border-radius:3px;display:inline-block;}

  /* ---------- TASK CARDS ---------- */
  .day-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px;}
  .day-card h3{margin:0 0 2px;font-style:italic;}
  .day-card .date{font-size:11px;color:var(--peach);margin-bottom:10px;}
  .mini-block{display:flex;align-items:center;gap:6px;font-size:11px;padding:3px 0;color:rgba(253,246,236,0.7);}
  .mini-block i{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
  .task-item{display:flex;align-items:flex-start;gap:8px;background:rgba(253,246,236,0.05);border-radius:9px;padding:8px 10px;margin-top:8px;}
  .task-item input[type=checkbox]{margin-top:2px;accent-color:var(--gold);}
  .task-item .txt{flex:1;font-size:12.5px;}
  .task-item .txt.done{text-decoration:line-through;opacity:.45;}
  .task-item .meta{font-size:10px;color:var(--peach);text-transform:uppercase;letter-spacing:.04em;}
  .task-item .del{background:none;border:none;color:rgba(253,246,236,0.4);cursor:pointer;font-size:14px;line-height:1;}
  .task-item .del:hover{color:var(--red);}
  details.add-task{margin-top:12px;}
  details.add-task summary{cursor:pointer;font-size:12px;color:var(--gold);list-style:none;}
  details.add-task summary::-webkit-details-marker{display:none;}
  details.add-task .box{margin-top:10px;display:flex;flex-direction:column;gap:8px;}

  /* ---------- 12 WEEK YEAR ---------- */
  .week-track{display:grid;grid-template-columns:repeat(12,1fr);gap:4px;margin-top:10px;}
  .wk-cell{aspect-ratio:1;border-radius:5px;background:rgba(253,246,236,0.08);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:9px;color:rgba(253,246,236,0.4);border:1px solid transparent;}
  .wk-cell.done{background:linear-gradient(135deg,var(--gold),var(--magenta));color:var(--noir);font-weight:700;}
  .wk-cell.current{border-color:var(--gold);}
  .goal-card{background:rgba(253,246,236,0.05);border-radius:12px;padding:14px 16px;margin-bottom:14px;}
  .goal-top{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;}

  /* ---------- REVIEW FORM ---------- */
  .review-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  @media(max-width:760px){.review-grid{grid-template-columns:1fr;}}
  .mood-row{display:flex;gap:8px;flex-wrap:wrap;}
  .mood-btn{padding:8px 14px;border-radius:999px;border:1px solid rgba(253,246,236,0.2);background:rgba(253,246,236,0.05);color:var(--cream);cursor:pointer;font-size:13px;}
  .mood-btn.sel{background:linear-gradient(120deg,var(--magenta),var(--burgundy));border-color:transparent;font-weight:600;}

  /* ---------- BUDGET ---------- */
  table.budget-table{width:100%;border-collapse:collapse;font-size:13px;}
  table.budget-table th{text-align:left;font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--peach);padding:6px 8px;border-bottom:1px solid var(--line);}
  table.budget-table td{padding:8px;border-bottom:1px solid var(--line);vertical-align:middle;}
  table.budget-table input{padding:6px 8px;font-size:12.5px;}
  .cat-bar-track{height:8px;background:rgba(253,246,236,0.08);border-radius:999px;overflow:hidden;margin-top:5px;}
  .cat-bar-fill{height:100%;background:linear-gradient(90deg,var(--gold),var(--red));}
  .stat-tile{background:rgba(253,246,236,0.06);border-radius:12px;padding:16px;text-align:center;}
  .stat-tile .num{font-family:'Playfair Display',serif;font-style:italic;font-size:26px;}
  .stat-tile .lbl{font-size:10.5px;text-transform:uppercase;letter-spacing:.08em;color:var(--peach);margin-top:4px;}

  /* ---------- MODAL ---------- */
  .modal-overlay{position:fixed;inset:0;background:rgba(20,10,10,0.78);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;z-index:50;padding:20px;}
  .modal-overlay.show{display:flex;}
  .modal-box{
    background:linear-gradient(160deg, #2a1712, var(--noir));
    border:1px solid rgba(253,246,236,0.15);
    border-radius:20px;max-width:480px;width:100%;padding:30px;box-shadow:0 30px 80px rgba(0,0,0,0.6);
    position:relative;
  }
  .modal-box .eyebrow{color:var(--gold);font-size:11px;letter-spacing:.2em;text-transform:uppercase;margin-bottom:6px;}
  .modal-box h2{font-size:26px;margin:0 0 4px;font-style:italic;}
  .modal-box p.hint{font-size:12.5px;color:rgba(253,246,236,0.6);margin-bottom:20px;}
  .modal-box .nn-input{display:flex;gap:8px;align-items:center;margin-bottom:8px;}
  .modal-box .nn-input span{font-family:'Playfair Display',serif;font-style:italic;color:var(--gold);width:16px;}
  .modal-actions{display:flex;justify-content:space-between;align-items:center;margin-top:20px;}
  .skip-link{background:none;border:none;color:rgba(253,246,236,0.45);font-size:12px;cursor:pointer;text-decoration:underline;}

  .toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:linear-gradient(120deg,var(--gold),var(--peach));color:var(--noir);padding:10px 20px;border-radius:999px;font-size:13px;font-weight:600;box-shadow:var(--shadow);z-index:80;opacity:0;pointer-events:none;transition:.3s;}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(-6px);}

  .empty{font-size:12.5px;color:rgba(253,246,236,0.4);font-style:italic;padding:10px 0;}
  hr.soft{border:none;border-top:1px solid var(--line);margin:16px 0;}
</style>
</head>
<body>

<div class="wrap">
  <header class="top">
    <div>
      <p class="brand-eyebrow">Weekly Command Center</p>
      <h1 class="brand-title">Walk in it.</h1>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
      <button class="btn btn-ghost btn-sm" id="prevWeekBtn" title="Previous week">←</button>
      <div class="week-badge" id="weekBadge">Loading week…</div>
      <button class="btn btn-ghost btn-sm" id="nextWeekBtn" title="Next week">→</button>
      <button class="btn btn-gold btn-sm" id="todayWeekBtn" style="display:none;">Today</button>
    </div>
  </header>

  <nav class="tabs" id="tabNav">
    <button data-tab="dashboard" class="active">Dashboard</button>
    <button data-tab="schedule">Schedule</button>
    <button data-tab="tasks">Tasks</button>
    <button data-tab="twelveweek">12 Week Year</button>
    <button data-tab="review">Friday Review</button>
    <button data-tab="budget">Budget</button>
  </nav>

  <!-- ============ DASHBOARD ============ -->
  <section class="tab active" id="tab-dashboard">
    <div class="grid-2">
      <div class="card">
        <h2>This week vs last week</h2>
        <p class="sub">Task completion</p>
        <div class="prog-row">
          <div class="prog-label">This week</div>
          <div class="prog-track"><div class="prog-fill" id="progThis" style="width:0%"></div></div>
          <div class="prog-pct" id="progThisPct">0%</div>
        </div>
        <div class="prog-row">
          <div class="prog-label">Last week</div>
          <div class="prog-track"><div class="prog-fill" id="progLast" style="width:0%;background:linear-gradient(90deg,var(--peach),var(--burgundy));"></div></div>
          <div class="prog-pct" id="progLastPct">0%</div>
        </div>
        <p class="empty" id="progNote"></p>
      </div>

      <div class="card">
        <h2>Non-negotiables</h2>
        <p class="sub">This week</p>
        <div id="nnList"></div>
        <button class="btn btn-ghost btn-sm" id="openIntentionBtn" style="margin-top:8px;">Set weekly intention</button>
      </div>
    </div>

    <div class="grid-2">
      <div class="card">
        <h2>12 Week Year — priorities</h2>
        <p class="sub" id="twYearSub">Week — of 12</p>
        <div id="dashGoals"></div>
      </div>

      <div class="card">
        <h2>Rotation</h2>
        <p class="sub">Evening swaps</p>
        <div class="toggle-row">
          <div>
            <div style="font-weight:500;">Wednesday</div>
            <div style="font-size:11px;color:rgba(253,246,236,0.5);">Bible Study / Free evening</div>
          </div>
          <div class="switch" id="toggleWed"><span class="lbl l">Bible</span><span class="lbl r">Free</span><div class="knob"></div></div>
        </div>
        <div class="toggle-row">
          <div>
            <div style="font-weight:500;">Thursday</div>
            <div style="font-size:11px;color:rgba(253,246,236,0.5);">Therapy / Rest evening</div>
          </div>
          <div class="switch" id="toggleThu"><span class="lbl l">Therapy</span><span class="lbl r">Rest</span><div class="knob"></div></div>
        </div>

        <hr class="soft">
        <h2 style="font-size:16px;">Google Calendar</h2>
        <p class="sub" id="gcalStatus">Not connected</p>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <button class="btn btn-gold btn-sm" id="gcalConnectBtn">Sign in with Google</button>
          <button class="btn btn-ghost btn-sm" id="gcalPushBtn" style="display:none;">Push this week to Calendar</button>
          <button class="btn btn-ghost btn-sm" id="gcalPullBtn" style="display:none;">Pull this week from Calendar</button>
        </div>
        <p class="empty" style="margin-top:8px;">Prefer not to sign in? <span class="skip-link" id="gcalIcsBtn">Download a .ics file instead</span> and import it manually.</p>
      </div>
    </div>

    <div class="card" id="gcalEventsCard" style="display:none;">
      <h2>From your Google Calendar</h2>
      <p class="sub">This week — pulled in read-only, for reference alongside your schedule</p>
      <div id="gcalEventsList"></div>
    </div>
  </section>

  <!-- ============ SCHEDULE ============ -->
  <section class="tab" id="tab-schedule">
    <div class="card">
      <h2>Weekly Schedule</h2>
      <p class="sub">Color-coded time blocks — toggle each day's mode</p>
      <div class="sched-controls" id="modeControls"></div>
      <p class="sub" style="margin-top:4px;">Late-night gym — aim for 3–4 nights</p>
      <div class="sched-controls" id="gymControls"></div>
      <div class="sched-scroll">
        <div class="sched-grid" id="schedGrid"></div>
      </div>
      <div class="legend" id="legend"></div>
    </div>
  </section>

  <!-- ============ TASKS ============ -->
  <section class="tab" id="tab-tasks">
    <div class="card">
      <h2>Tasks by Day</h2>
      <p class="sub">Mon – Fri · tie each task to a 12 Week Year focus</p>
      <div class="day-cards" id="dayCards"></div>
    </div>
  </section>

  <!-- ============ 12 WEEK YEAR ============ -->
  <section class="tab" id="tab-twelveweek">
    <div class="grid-2">
      <div class="card">
        <h2>Program</h2>
        <p class="sub" id="twSub2">Week — of 12</p>
        <p class="empty" id="twDates"></p>
        <button class="btn btn-ghost btn-sm" id="resetProgramBtn">Start a new 12-week cycle</button>
      </div>
      <div class="card">
        <h2>This week's execution</h2>
        <p class="sub">The scoreboard — your only real lead indicator</p>
        <div class="stat-tile" id="scoreTile" style="text-align:left;padding:10px 0;">
          <div class="num" id="scorePct">—</div>
          <div class="lbl">tactics completed this week</div>
        </div>
        <p class="empty">85%+ execution weeks are what actually move the needle — not the weeks you feel busy.</p>
      </div>
    </div>

    <div class="card">
      <h2>12-Week Vision</h2>
      <p class="sub">If these 12 weeks go exactly right, what does that look like?</p>
      <textarea id="visionText" placeholder="Paint the picture — what's true at the end of week 12 that isn't true today?"></textarea>
    </div>

    <div class="card">
      <h2>Goals</h2>
      <p class="sub">2–3 goals max. Each one needs weekly tactics — the actions that actually move it.</p>
      <div id="goalsFull"></div>
      <details class="add-task">
        <summary>+ Add a 12-week goal</summary>
        <div class="box">
          <div class="field"><label>Goal</label><input type="text" id="goalTitle" placeholder="e.g. Post lifestyle content 4x/week"></div>
          <div class="field"><label>Priority</label>
